# =====================================================
# RELANCEPRO AFRICA - Configuration Environnement
# =====================================================

# Application
NEXT_PUBLIC_APP_URL=https://relancepro.africa
NEXT_PUBLIC_APP_NAME=RelancePro Africa

# Base de données PostgreSQL (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/relancepro?schema=public"

# NextAuth
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
NEXTAUTH_URL=https://relancepro.africa

# Paystack (Paiements Afrique)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxx

# Resend (Emails)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@relancepro.africa

# WhatsApp (Whapi.cloud)
WHAPI_API_KEY=your-whapi-api-key
WHAPI_PHONE_NUMBER=+224620000000

# IA (Optionnel - pour relances intelligentes)
OPENAI_API_KEY=sk-xxxxx

# Admin
ADMIN_EMAIL=admin@relancepro.africa

# Cron Jobs
CRON_SECRET=your-cron-secret-key-change-in-production

# =====================================================
# PUSH NOTIFICATIONS (Web Push API)
# =====================================================
# Générer les clés VAPID avec: npx web-push generate-vapid-keys
# La clé publique est exposée au client, la clé privée reste côté serveur

# Clé publique VAPID (exposée au navigateur)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Clé privée VAPID (secrète, côté serveur uniquement)
VAPID_PRIVATE_KEY=

# Sujet VAPID (mailto: ou https://)
# Format: mailto:votre@email.com ou https://votre-site.com
VAPID_SUBJECT=mailto:contact@relancepro.africa
