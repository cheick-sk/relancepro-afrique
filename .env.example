# RelancePro Africa - Environment Variables
# Copy this file to .env and fill in your values

# =====================================================
# DATABASE (PostgreSQL for production)
# =====================================================
DATABASE_URL="postgresql://user:password@host:5432/relancepro?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/relancepro?sslmode=require"

# For local development with SQLite:
# DATABASE_URL="file:./prisma/dev.db"
# DIRECT_DATABASE_URL="file:./prisma/dev.db"

# =====================================================
# NEXTAUTH (Authentication)
# =====================================================
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# =====================================================
# CRON JOBS
# =====================================================
CRON_SECRET="your-cron-secret-for-api-authentication"
CRON_ENABLED="true"

# =====================================================
# EMAIL (Resend)
# =====================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# =====================================================
# PAYMENTS (Paystack - African payments)
# =====================================================
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_live_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# =====================================================
# WHATSAPP (Whapi.cloud)
# =====================================================
WHATSAPP_API_KEY="your-whapi-cloud-api-key"
WHATSAPP_WEBHOOK_SECRET="your-whatsapp-webhook-secret"

# =====================================================
# SMS - TWILIO
# =====================================================
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# =====================================================
# SMS - AFRICA'S TALKING
# =====================================================
AFRICASTALKING_API_KEY="your-africastalking-api-key"
AFRICASTALKING_USERNAME="your-username"
AFRICASTALKING_SENDER_ID="RELANCER" # Optional sender ID

# =====================================================
# APP CONFIGURATION
# =====================================================
NEXT_PUBLIC_APP_NAME="RelancePro Africa"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="GNF"
NEXT_PUBLIC_DEFAULT_LOCALE="fr"

# =====================================================
# SUBSCRIPTION PLANS (in GNF - Guinean Franc)
# =====================================================
# Starter: 50,000 GNF/month (~$5)
# Business: 150,000 GNF/month (~$15)
# Enterprise: 500,000 GNF/month (~$50)
NEXT_PUBLIC_PLAN_STARTER_PRICE="50000"
NEXT_PUBLIC_PLAN_BUSINESS_PRICE="150000"
NEXT_PUBLIC_PLAN_ENTERPRISE_PRICE="500000"

# =====================================================
# OPTIONAL - EXTERNAL INTEGRATIONS
# =====================================================
# QuickBooks Online
# QUICKBOOKS_CLIENT_ID=""
# QUICKBOOKS_CLIENT_SECRET=""

# Xero
# XERO_CLIENT_ID=""
# XERO_CLIENT_SECRET=""

# Sage
# SAGE_CLIENT_ID=""
# SAGE_CLIENT_SECRET=""

# Wave
# WAVE_CLIENT_ID=""
# WAVE_CLIENT_SECRET=""

# =====================================================
# OPTIONAL - AI FEATURES (uses z-ai-web-dev-sdk)
# =====================================================
# AI features work out of the box with the SDK
# No additional configuration needed
